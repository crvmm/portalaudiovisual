{
  "name": "portal-audiovisual",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:gen-types": "supabase gen types typescript --local > src/types/database.ts",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "build:pages": "bash scripts/prepare-pages-deploy.sh",
    "deploy": "bash scripts/prepare-pages-deploy.sh && CLOUDFLARE_ACCOUNT_ID=852e6fbe0ecd3f7d68a85f820f49bf10 wrangler pages deploy --project-name=portalaudiovisual --branch=main --commit-dirty=true",
    "deploy:workers": "opennextjs-cloudflare build && CLOUDFLARE_ACCOUNT_ID=852e6fbe0ecd3f7d68a85f820f49bf10 wrangler deploy --config wrangler.workers.jsonc",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "supabase": "^2.24.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "wrangler": "^4.110.0"
  }
}
