# Supabase local — copia a .env.local y ajusta tras `supabase start`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Solo para procesamiento de emails en servidor (opcional)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Para la edge function de emails (opcional, configurar en Supabase secrets)
# RESEND_API_KEY=re_xxx
# FROM_EMAIL=Audiovisual Jobs <noreply@tudominio.com>
